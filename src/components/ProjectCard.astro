---
import { ArrowRight } from './icons/ArrowRight';

interface Props {
  title: string;
  year: number;
  description: string;
  heroImage: string;
  heroImageAlign?: 'center' | 'top' | 'bottom';
  url?: string;
  imageStyle?: 'cover' | 'icon';
}

const { year, title, description, url, heroImage, heroImageAlign = 'center', imageStyle = 'cover' } = Astro.props;
const linkTarget = url?.startsWith('http') ? '_blank' : '_self';
---

<a href={url || '#'} target={linkTarget} rel={linkTarget === '_blank' ? 'noopener noreferrer' : undefined} class="group block">
  <div class="rounded-2xl border border-[#2A3441] bg-[#0f1219] overflow-hidden transition-all duration-300 group-hover:border-[#3A4A5A] group-hover:bg-[#131922]">
    <!-- Image area -->
    {imageStyle === 'icon' ? (
      <div class="flex items-center justify-center h-48 bg-gradient-to-b from-[#1a2130] to-[#0f1219]">
        <img
          src={heroImage}
          alt={title}
          class="w-20 h-20 rounded-2xl transition-transform duration-500 group-hover:scale-110"
        />
      </div>
    ) : (
      <div class="overflow-hidden">
        <img
          src={heroImage}
          alt={title}
          class:list={[
            'w-full h-48 object-cover transition-transform duration-500 group-hover:scale-105',
            { 'object-top': heroImageAlign === 'top' },
            { 'object-center': heroImageAlign === 'center' },
            { 'object-bottom': heroImageAlign === 'bottom' }
          ]}
        />
      </div>
    )}

    <!-- Content -->
    <div class="p-5 space-y-3">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-white">{title}</h3>
        <span class="text-xs text-zinc-500 tabular-nums">{year}</span>
      </div>
      <p class="text-sm text-zinc-400 leading-relaxed line-clamp-2">{description}</p>
      <span class="inline-flex items-center text-sm text-emerald-400 group-hover:text-emerald-300 transition-colors">
        View project
        <ArrowRight className="ml-1 w-3.5 h-3.5 transition-all duration-300 group-hover:ml-2" />
      </span>
    </div>
  </div>
</a>
