---
import { ArrowRight } from './icons/ArrowRight';

interface Props {
  title: string;
  year: number;
  description: string;
  heroImage: string;
  heroImageAlign?: 'center' | 'top' | 'bottom';
  url?: string;
  imageStyle?: 'cover' | 'icon';
  label?: string;
}

const { year, title, description, url, heroImage, heroImageAlign = 'center', imageStyle = 'cover', label } = Astro.props;
const linkTarget = url?.startsWith('http') ? '_blank' : '_self';
---

<a href={url || '#'} target={linkTarget} rel={linkTarget === '_blank' ? 'noopener noreferrer' : undefined} class="group block reveal">
  <div class="project-card rounded-2xl border border-[var(--t-border)] bg-[var(--t-bg-card)] overflow-hidden transition-all duration-300">
    <!-- Image area -->
    {imageStyle === 'icon' ? (
      <div class="flex items-center justify-center h-48 bg-[var(--t-bg-elevated)]">
        <img
          src={heroImage}
          alt={title}
          class="w-20 h-20 rounded-2xl transition-transform duration-500 group-hover:scale-110"
        />
      </div>
    ) : (
      <div class="overflow-hidden">
        <img
          src={heroImage}
          alt={title}
          class:list={[
            'w-full h-48 object-cover transition-transform duration-500 group-hover:scale-105',
            { 'object-top': heroImageAlign === 'top' },
            { 'object-center': heroImageAlign === 'center' },
            { 'object-bottom': heroImageAlign === 'bottom' }
          ]}
        />
      </div>
    )}

    <!-- Content -->
    <div class="p-5 space-y-3">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-semibold text-[var(--t-text-primary)]">{title}</h3>
        <span class="text-xs text-[var(--t-text-muted)] tabular-nums">{year}</span>
      </div>
      <p class="text-sm text-[var(--t-text-body)] leading-relaxed line-clamp-2">{description}</p>
      <span class="inline-flex items-center text-sm text-[var(--t-accent)] group-hover:text-[var(--t-accent-hover)] transition-colors">
        {label || "View project"}
        <ArrowRight className="ml-1 w-3.5 h-3.5 transition-all duration-300 group-hover:ml-2" />
      </span>
    </div>
  </div>
</a>

<style>
  .project-card {
    transition: transform 0.3s cubic-bezier(0.33, 1, 0.68, 1),
                box-shadow 0.3s cubic-bezier(0.33, 1, 0.68, 1),
                border-color 0.3s ease;
  }
  .group:hover .project-card {
    border-color: var(--t-border-hover);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px -12px rgba(0, 0, 0, 0.35);
  }
  html[data-theme="light"] .group:hover .project-card {
    box-shadow: 0 12px 40px -12px rgba(0, 0, 0, 0.1);
  }
  .group:active .project-card {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px -8px rgba(0, 0, 0, 0.2);
    transition-duration: 0.1s;
  }
</style>
