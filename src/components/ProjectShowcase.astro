---
import { ArrowRight } from './icons/ArrowRight';

interface Stat {
  value: string;
  label: string;
}

interface Props {
  title: string;
  year: number;
  description: string;
  heroImage: string;
  heroImageAlign?: 'center' | 'top' | 'bottom';
  url?: string;
  imageStyle?: 'cover' | 'icon';
  label?: string;
  tags?: string[];
  stats?: Stat[];
  status?: string;
  index: number;
  isLast?: boolean;
}

const {
  year, title, description, url, heroImage,
  heroImageAlign = 'center', imageStyle = 'cover',
  label, tags = [], stats, status, index, isLast = false
} = Astro.props;

const linkTarget = url?.startsWith('http') ? '_blank' : '_self';
const num = String(index + 1).padStart(2, '0');
const hasCoverImage = imageStyle === 'cover';
const hasStats = stats && stats.length > 0;
const isReversed = index % 2 !== 0;
---

<div class="reveal">
  <a
    href={url || '#'}
    target={linkTarget}
    rel={linkTarget === '_blank' ? 'noopener noreferrer' : undefined}
    class="project-entry group block"
  >
    {hasCoverImage ? (
      <!-- Cover image project: full-width image with text overlay area below -->
      <div>
        <div class="cover-frame rounded-[24px] overflow-hidden border border-[var(--t-border)]">
          <img
            src={heroImage}
            alt={title}
            class:list={[
              'w-full h-[280px] md:h-[400px] object-cover transition-transform duration-700 group-hover:scale-[1.03]',
              { 'object-top': heroImageAlign === 'top' },
              { 'object-center': heroImageAlign === 'center' },
              { 'object-bottom': heroImageAlign === 'bottom' }
            ]}
          />
        </div>
        <div class="mt-8 flex flex-col md:flex-row md:items-start md:justify-between gap-6">
          <div class="max-w-xl">
            <div class="flex items-center gap-3 mb-3">
              <span class="text-[var(--t-accent)] text-sm font-mono">{num}</span>
              <span class="text-xs text-[var(--t-text-muted)] tabular-nums">{year}</span>
            </div>
            <h3 class="text-2xl md:text-3xl font-semibold text-[var(--t-text-primary)] tracking-[-0.03em] leading-tight group-hover:text-[var(--t-accent)] transition-colors duration-300">{title}</h3>
            <p class="mt-3 text-[var(--t-text-body)] leading-relaxed">{description}</p>
          </div>
          <div class="flex flex-col items-start md:items-end gap-4 shrink-0 md:pt-8">
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-x-3 gap-y-1 md:justify-end">
                {tags.map((tag: string) => (
                  <span class="text-[11px] text-[var(--t-text-muted)] tracking-wide">{tag}</span>
                ))}
              </div>
            )}
            <span class="project-link inline-flex items-center text-sm text-[var(--t-accent)] group-hover:text-[var(--t-accent-hover)] transition-colors">
              {label || "View project"}
              <ArrowRight className="ml-1.5 w-3.5 h-3.5 transition-all duration-300 group-hover:ml-3" />
            </span>
          </div>
        </div>
      </div>
    ) : (
      <!-- Icon project: split layout with composed visual -->
      <div class:list={[
        "flex flex-col md:flex-row gap-8 md:gap-0 items-stretch",
        { "md:flex-row-reverse": isReversed }
      ]}>
        <!-- Visual side -->
        <div class="w-full md:w-[45%] shrink-0">
          <div class="icon-frame h-full min-h-[280px] md:min-h-[360px] rounded-[24px] border border-[var(--t-border)] bg-[var(--t-bg-card)] overflow-hidden relative flex items-center justify-center">
            <!-- Large faint title as texture -->
            <div class="absolute inset-0 flex items-center justify-center overflow-hidden pointer-events-none select-none">
              <span class="text-[clamp(4rem,12vw,8rem)] font-bold text-[var(--t-text-primary)] opacity-[0.08] tracking-[-0.05em] whitespace-nowrap">{title}</span>
            </div>
            <!-- Icon -->
            <img
              src={heroImage}
              alt={title}
              class="relative z-10 w-28 h-28 md:w-36 md:h-36 rounded-3xl transition-transform duration-500 group-hover:scale-110"
            />
            <!-- Accent corner mark -->
            <div class="absolute top-5 left-5 w-6 h-px bg-[var(--t-accent)] opacity-40"></div>
            <div class="absolute top-5 left-5 w-px h-6 bg-[var(--t-accent)] opacity-40"></div>
          </div>
        </div>

        <!-- Content side -->
        <div class:list={[
          "w-full md:w-[55%] flex flex-col justify-center",
          isReversed ? "md:pr-12" : "md:pl-12"
        ]}>
          <div class="flex items-center gap-3 mb-4">
            <span class="text-[var(--t-accent)] text-sm font-mono">{num}</span>
            <span class="text-xs text-[var(--t-text-muted)] tabular-nums">{year}</span>
            {status && (
              <span class="text-xs text-[var(--t-accent)] font-medium ml-2">{status}</span>
            )}
            {label && !status && (
              <span class="text-xs text-[var(--t-text-muted)] ml-2">{label}</span>
            )}
          </div>

          <h3 class="text-2xl md:text-3xl font-semibold text-[var(--t-text-primary)] tracking-[-0.03em] leading-tight group-hover:text-[var(--t-accent)] transition-colors duration-300">{title}</h3>

          <p class="mt-4 text-[var(--t-text-body)] leading-relaxed">{description}</p>

          <!-- Stats -->
          {hasStats && (
            <div class="flex gap-8 mt-8 pt-6 border-t border-[var(--t-border)]">
              {stats.map((stat: Stat) => (
                <div>
                  <div class="text-xl md:text-2xl font-semibold text-[var(--t-text-primary)] tracking-tight">{stat.value}</div>
                  <div class="text-[11px] text-[var(--t-text-muted)] mt-0.5 tracking-wide">{stat.label}</div>
                </div>
              ))}
            </div>
          )}

          <!-- Tags + link -->
          <div class="flex items-center justify-between gap-4 mt-8">
            {tags.length > 0 && (
              <div class="flex flex-wrap gap-x-3 gap-y-1">
                {tags.map((tag: string) => (
                  <span class="text-[11px] text-[var(--t-text-muted)] tracking-wide">{tag}</span>
                ))}
              </div>
            )}
            <span class="project-link inline-flex items-center text-sm text-[var(--t-accent)] group-hover:text-[var(--t-accent-hover)] transition-colors shrink-0">
              {label || "View project"}
              <ArrowRight className="ml-1.5 w-3.5 h-3.5 transition-all duration-300 group-hover:ml-3" />
            </span>
          </div>
        </div>
      </div>
    )}
  </a>

  {!isLast && (
    <div class="my-20 md:my-28"></div>
  )}
</div>

<style>
  .icon-frame {
    transition: border-color 0.3s ease, box-shadow 0.4s cubic-bezier(0.33, 1, 0.68, 1), transform 0.4s cubic-bezier(0.33, 1, 0.68, 1);
    background-color: var(--t-bg-card);
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.18) 1px, transparent 1px);
    background-size: 24px 24px;
    background-position: 12px 12px;
  }

  html[data-theme="light"] .icon-frame {
    background-image: radial-gradient(circle, rgba(28, 25, 23, 0.18) 1px, transparent 1px);
  }

  .group:hover .icon-frame {
    border-color: var(--t-border-hover);
    box-shadow: 0 20px 60px -20px rgba(0, 0, 0, 0.3);
    transform: translateY(-3px);
  }

  html[data-theme="light"] .group:hover .icon-frame {
    box-shadow: 0 20px 60px -20px rgba(0, 0, 0, 0.08);
  }

  .cover-frame {
    transition: border-color 0.3s ease, box-shadow 0.4s cubic-bezier(0.33, 1, 0.68, 1), transform 0.4s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .group:hover .cover-frame {
    border-color: var(--t-border-hover);
    box-shadow: 0 24px 64px -20px rgba(0, 0, 0, 0.35);
    transform: translateY(-3px);
  }

  html[data-theme="light"] .group:hover .cover-frame {
    box-shadow: 0 24px 64px -20px rgba(0, 0, 0, 0.1);
  }

  .project-link {
    position: relative;
  }

  .project-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--t-accent);
    transition: width 0.3s cubic-bezier(0.33, 1, 0.68, 1);
  }

  .group:hover .project-link::after {
    width: calc(100% - 1.25rem);
  }
</style>
