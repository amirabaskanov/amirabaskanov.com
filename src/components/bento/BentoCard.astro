---
import type { FC, SVGProps } from 'react'
import BentoBadge from './BentoBadge'

interface Props {
  title?: string;
  icon?: FC<SVGProps<SVGSVGElement>>;
  colSpan?: boolean;
  isWide?: boolean;
  className?: string;
}

const { title, icon: Icon, colSpan, isWide, className } = Astro.props;
---

<div class={`bento-card group relative rounded-[32px] border border-[var(--t-border)] bg-[var(--t-bg-card)] overflow-hidden transition-all duration-300 ${isWide ? 'col-span-3' : colSpan ? 'col-span-2' : ''} ${className || ''}`}>
  <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition duration-300 [background:radial-gradient(600px_circle_at_var(--mouse-x)_var(--mouse-y),var(--t-glow),transparent_40%)]" />

  <div class="p-6 h-full">
    {title && Icon && (
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-2 bg-[var(--t-bg-elevated)] border border-[var(--t-border)] rounded-full py-1.5 px-3">
          <Icon className="size-5 text-[var(--t-icon-color)]" />
          <span class="text-sm font-medium text-[var(--t-text-primary)]">{title}</span>
        </div>
      </div>
    )}
    <slot />
  </div>
</div>

<style>
  .bento-card:hover {
    border-color: var(--t-border-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px -8px rgba(0, 0, 0, 0.3);
  }
  html[data-theme="light"] .bento-card:hover {
    box-shadow: 0 8px 32px -8px rgba(0, 0, 0, 0.08);
  }
  .bento-card:active {
    transform: translateY(0);
    box-shadow: none;
    transition-duration: 0.1s;
  }
</style>
