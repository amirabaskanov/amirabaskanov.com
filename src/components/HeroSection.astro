---
import Keyboard from "@/components/Keyboard.astro";
import HeroShelf from "@/components/shelf/HeroShelf.astro";
import "../styles/global.css";
---

<section class="w-full max-w-[1120px] mx-auto flex px-4 h-screen items-center">
  <!-- Left: content -->
  <div class="w-full md:w-3/5 flex flex-col gap-8">
    <div
      class="invisible flex w-fit items-center rounded-full gap-3 py-1.5 pl-3 pr-4 border border-[var(--t-border-subtle)] bg-[var(--t-bg-card)]/25 will-change-transform will-change-opacity animate-fade-up"
    >
      <div class="relative size-3">
        <div class="absolute size-full animate-ping rounded-full bg-[var(--t-badge-dot-ping)]">
        </div>
        <div class="drop-shadow-green size-full rounded-full bg-[var(--t-badge-dot)]"></div>
      </div>
      <h3 class="text-sm text-[var(--t-text-heading)] max-xs:text-xs">
        Based in San Francisco
      </h3>
    </div>

    <h1
      class="invisible text-[var(--t-text-primary)] will-change-transform will-change-opacity animate-fade-up-200 text-[clamp(2rem,7vw,3rem)] font-medium leading-[1.05] tracking-tight"
    >
      Hi, I'm Amir. <br /> A software engineer.
    </h1>

    <h2
      class="invisible will-change-transform will-change-opacity animate-fade-up-400 mb-8 max-w-xl leading-relaxed text-[var(--t-text-body)] max-sm:text-sm"
    >
      I build AI-powered products, from ML models in production to full-stack features that ship. Based in San Francisco.
    </h2>

    <Keyboard class="invisible will-change-transform will-change-opacity animate-fade-up-600" />
  </div>

  <!-- Right: 3D shelf (desktop only) -->
  <div class="hidden md:flex w-2/5 h-[500px] items-center justify-center">
    <HeroShelf />
  </div>
</section>

<style>
  :global(*) {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>
