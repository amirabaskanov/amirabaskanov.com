---
import { ArrowOutward } from '@icons/ArrowOutward'
import Link from '@/components/Link'
// import { mainMetaData } from '@/lib/metaData'

import { SOCIAL_MEDIA_DATA } from '../SocialMediaData'
// import LastUpdatedTime from './LastUpdatedTime.astro'
import { Instagram } from '@icons/Instagram'
import { icon } from 'leaflet'

type FooterContent = {
  title: string
  links: {
    text: string
    href: string
    withIcon?: boolean
    inNewTab?: boolean
  }[]
}

const socialMediaData = [
  // CHANGE
  ...SOCIAL_MEDIA_DATA,
//   { icon: Instagram, href: 'https://instagram.com/amirabaskanov', name: 'instagram' }
]

const FOOTER_CONTENTS: FooterContent[] = [
//   {
//     title: 'Me',
//     links: [
//       { text: 'Blog', href: '/blog' },
//     ]
//   },
  {
    title: 'This site',
    links: [
      {
        text: 'Source code',
        href: 'https://github.com/amirabaskanov/amirabaskanov.com',
        inNewTab: true
      },
    //   {
    //     text: 'Analytics',
    //     // Change
    //     href: 'https://us.umami.is/websites/f1268456-1a63-4072-b4e8-93b4dd501de9',
    //     inNewTab: true
    //   },
    ]
  },
  {
    title: 'Elsewhere',
    links: [
      {
        text: 'Monkeytype',
        href: 'https://monkeytype.com/profile/amir11',
        inNewTab: true,
        withIcon: true
      }
    ]
  }
]
---


<footer class='relative mt-auto w-full'>
  <div
    class:list={[
      '-z-10 h-48 w-3/5 opacity-25 blur-[160px]',
      'absolute left-1/2 top-0 -translate-x-1/2 xs:top-24'
    ]}
  >
  </div>

  <!-- separator -->
  <div
    class:list={[
      'h-[1px] w-full',
      'bg-gradient-to-r from-[var(--t-separator-from)] via-[var(--t-separator-via)] to-[var(--t-separator-from)]'
    ]}
  >
  </div>

  <!-- footer content -->
  <div class='reveal flex justify-center bg-[var(--t-bg-page)] pb-16 pt-20 max-[960px]:pb-8'>
    <div
      class:list={[
        'flex items-stretch justify-between text-sm tracking-wide',
        'w-full max-w-[1120px] px-4',
        'gap-16 max-[960px]:flex-col-reverse'
      ]}
    >
      <div class='space-y-24'>
        <div class='space-y-3'>
          <p class='text-lg leading-none text-[var(--t-text-heading)]'>Amir</p>
          <p class='flex text-[13px] text-[var(--t-text-muted)]'>
            Software Engineer &nbsp;<Link href={"https://salesfinity.ai"} target="_blank" class='flex items-center gap-1 font-normal hover:text-[var(--t-text-heading)]'> @Salesfinity <ArrowOutward className='size-3'/></Link>
          </p>
          <p class='flex text-[13px] text-[var(--t-text-muted)]'>
            Software Engineer &nbsp;<Link href={"https://growthhungry.life"} target="_blank" class='flex items-center gap-1 font-normal hover:text-[var(--t-text-heading)]'> @Growthhungry <ArrowOutward className='size-3'/></Link>
          </p>
          <p class='flex text-[13px] text-[var(--t-text-muted)]'>
            Software Engineer Intern&nbsp;<Link href={"https://www.kodif.ai/"} target="_blank" class='flex items-center gap-1 font-normal hover:text-[var(--t-text-heading)]'> @Kodif <ArrowOutward className='size-3'/></Link>
          </p>
        </div>
        <div class='space-y-6'>
          <ul class='flex gap-3 text-[var(--t-text-heading)]'>
            {
              socialMediaData.map(({ icon: Icon, href, name }) => (
                <li>
                  <Link
                    href={href}
                    target='_blank'
                    aria-label={name}
                    class='group'
                  >
                    <Icon className='size-5 rounded group-hover:text-[var(--t-accent)] transition-colors group-focus-within:outline outline-offset-4 outline-emerald-300' />
                  </Link>
                </li>
              ))
            }
          </ul>
          <p class='text-xs text-[var(--t-text-muted)]'>
            &copy; {new Date().getFullYear()} Amir. All rights reserved.
          </p>
        </div>
      </div>

      <div
        class:list={[
          'flex flex-col justify-between max-xs:gap-16',
          'max-[960px]:flex-col-reverse max-[960px]:gap-12',
          'text-[var(--t-text-heading)]'
        ]}
      >
        <div
          class='grid grid-cols-3 gap-y-16 max-[960px]:max-w-[480px] max-xs:grid-cols-2 sm:gap-24'
        >
          {
            FOOTER_CONTENTS.map(({ title, links }) => (
              <div class='space-y-4'>
                <p class='text-[var(--t-text-heading)]'>{title}</p>
                <ul class='flex flex-col gap-3 text-[var(--t-text-body)]'>
                  {links.map(({ text, href, withIcon, inNewTab }) => (
                    <li>
                      <Link
                        href={href}
                        target={inNewTab ? '_blank' : '_self'}
                        class='flex items-center gap-1 font-normal hover:text-[var(--t-text-heading)]'
                      >
                        <span>{text}</span>
                        {withIcon && <ArrowOutward className='size-3' />}
                      </Link>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
        <!-- <LastUpdatedTime class='text-[var(--t-text-muted)]' /> -->
      </div>
    </div>
  </div>
</footer>
