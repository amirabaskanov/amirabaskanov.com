---
const currentPath = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/blog", label: "Blog" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 flex justify-center pt-6 pointer-events-none">
  <div class="flex items-center gap-1 rounded-full border border-[var(--t-border-subtle)] bg-[var(--t-bg-card)]/80 backdrop-blur-md px-1.5 py-1.5 pointer-events-auto">
    {links.map(({ href, label }) => {
      const isActive = currentPath === href || (href !== "/" && currentPath.startsWith(href));
      return (
        <a
          href={href}
          class:list={[
            "px-4 py-1.5 rounded-full text-sm transition-colors",
            isActive
              ? "bg-[var(--t-bg-elevated)] text-[var(--t-text-primary)]"
              : "text-[var(--t-text-muted)] hover:text-[var(--t-text-primary)]"
          ]}
        >
          {label}
        </a>
      );
    })}
  </div>
</nav>
