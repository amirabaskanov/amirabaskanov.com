---
// import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import ScrollToTop from "../components/ScrollToTop.astro";
import "../styles/global.css";

interface Props {
  pageTitle?: string;
  description?: string;
}

const {
  pageTitle = "Amir Abaskanov | Software Engineer",
  description = "Software engineer building AI products. Based in San Francisco. Previously Kodif, Growthhungry."
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://amirabaskanov.com/og-image.png" />
    <meta property="og:url" content="https://amirabaskanov.com" />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://amirabaskanov.com/og-image.png" />

    <link rel="preload" href="/models/guitar-draco.glb" as="fetch" crossorigin type="model/gltf-binary" fetchpriority="low" />

    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body class='bg-no-repeat bg-[length:100%_auto] flex min-h-screen flex-col items-center bg-[var(--t-bg-page)] text-[var(--t-text-primary)] transition-colors duration-300' style="background-image: var(--_bg-img);">
    <!-- <Navigation /> -->

    <slot />

    <ThemeToggle />
    <ScrollToTop />
    <Footer/>
    <script>
      import "../scripts/menu.js";
    </script>
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
      );

      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

<style>
  :root {
    --_bg-img: url(/assets/images/og_background.png);
  }
  html[data-theme="light"] {
    --_bg-img: none;
  }
</style>
