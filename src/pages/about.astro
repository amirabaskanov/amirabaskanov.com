---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ArrowOutward } from "../components/icons/ArrowOutward";

const pageTitle = "About | Amir Abaskanov";

const timeline = [
  { label: "Now", text: "Software Engineer, building AI products in San Francisco" },
  { label: "2024", text: "Moved solo to SF after graduating" },
  { label: "2020", text: "Started at Bentley University, Boston" },
  { label: "Origin", text: "Central Asia" },
];

const interests = [
  { emoji: "🧗", label: "Rock climbing" },
  { emoji: "🎸", label: "Guitar" },
  { emoji: "🏯", label: "Japanese aesthetics" },
];

const links = [
  { label: "GitHub", href: "https://github.com/amirabaskanov" },
  { label: "LinkedIn", href: "https://linkedin.com/in/abaskanov" },
  { label: "Email", href: "mailto:amirabaskanov@gmail.com" },
];
---

<BaseLayout pageTitle={pageTitle} description="About Amir Abaskanov. Software engineer in San Francisco building AI products.">
  <main class="w-full max-w-[1120px] mx-auto px-4 py-32">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

      <!-- Bio card -->
      <div class="md:col-span-2 rounded-[32px] border border-[var(--t-border)] bg-[var(--t-bg-card)] p-8 md:p-10">
        <h1 class="text-2xl font-medium text-[var(--t-text-primary)] tracking-tight mb-6">About me</h1>
        <div class="space-y-4 text-[var(--t-text-body)] leading-relaxed max-w-[65ch]">
          <p>
            I'm Amir. I moved to the US for university at Bentley in Boston, and after
            graduating, relocated solo to San Francisco to be closer to the tech I wanted
            to build.
          </p>
          <p>
            Right now I work on AI-powered products, everything from ML models in production
            to full-stack features shipped end-to-end. Before that I built things at
            <a href="https://growthhungry.life" target="_blank" rel="noopener noreferrer" class="text-[var(--t-text-heading)] hover:text-[var(--t-accent)] transition-colors">Growthhungry</a>
            and interned at
            <a href="https://kodif.ai" target="_blank" rel="noopener noreferrer" class="text-[var(--t-text-heading)] hover:text-[var(--t-accent)] transition-colors">Kodif</a>.
          </p>
          <p>
            Outside of code I spend time rock climbing, playing guitar, and exploring
            Japanese aesthetics in design, architecture, and everyday objects. I like things
            that are simple and well-made.
          </p>
        </div>
      </div>

      <!-- Timeline card -->
      <div class="rounded-[32px] border border-[var(--t-border)] bg-[var(--t-bg-card)] p-8">
        <h2 class="text-sm font-medium text-[var(--t-text-muted)] mb-6">Timeline</h2>
        <div class="space-y-5">
          {timeline.map(({ label, text }) => (
            <div class="flex gap-4">
              <span class="text-xs text-[var(--t-accent)] font-medium tabular-nums w-12 shrink-0 pt-0.5">{label}</span>
              <span class="text-sm text-[var(--t-text-heading)]">{text}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Interests card -->
      <div class="rounded-[32px] border border-[var(--t-border)] bg-[var(--t-bg-card)] p-8">
        <h2 class="text-sm font-medium text-[var(--t-text-muted)] mb-6">Outside of code</h2>
        <div class="space-y-4">
          {interests.map(({ emoji, label }) => (
            <div class="flex items-center gap-3">
              <span class="text-lg">{emoji}</span>
              <span class="text-sm text-[var(--t-text-heading)]">{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Links card -->
      <div class="md:col-span-2 rounded-[32px] border border-[var(--t-border)] bg-[var(--t-bg-card)] p-8">
        <div class="flex flex-wrap gap-6">
          {links.map(({ label, href }) => (
            <a
              href={href}
              target={href.startsWith("mailto") ? undefined : "_blank"}
              rel={href.startsWith("mailto") ? undefined : "noopener noreferrer"}
              class="flex items-center gap-1.5 text-sm text-[var(--t-text-muted)] hover:text-[var(--t-accent)] transition-colors"
            >
              {label}
              <ArrowOutward className="size-3" />
            </a>
          ))}
        </div>
      </div>

    </div>
  </main>
</BaseLayout>
