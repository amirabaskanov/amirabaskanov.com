---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProjectHeader from '../components/ProjectHeader.astro';
import ProjectShowcase from '../components/ProjectShowcase.astro';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => {
  const orderA = a.data.order ?? 99;
  const orderB = b.data.order ?? 99;
  if (orderA !== orderB) return orderA - orderB;
  return b.data.year - a.data.year;
});
---

<BaseLayout pageTitle="Projects">
  <section class="w-full max-w-[1120px] mx-auto px-4 pt-40 pb-28">
    <a href="/" class="invisible animate-fade-up inline-flex items-center gap-2 text-sm text-[var(--t-text-body)] hover:text-[var(--t-text-heading)] transition-colors mb-12 group">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to home
    </a>

    <div class="invisible animate-fade-up">
      <ProjectHeader forHomePage />
    </div>

    <div class="mt-20">
      {sortedProjects.map((project, index) => (
        <ProjectShowcase
          title={project.data.title}
          year={project.data.year}
          description={project.data.description}
          heroImage={project.data.heroImage}
          heroImageAlign={project.data.heroImageAlign}
          url={project.data.url}
          imageStyle={project.data.imageStyle}
          label={project.data.label}
          tags={project.data.tags}
          stats={project.data.stats}
          status={project.data.status}
          index={index}
          isLast={index === sortedProjects.length - 1}
        />
      ))}
    </div>
  </section>
</BaseLayout>
