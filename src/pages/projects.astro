---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ProjectHeader from '../components/ProjectHeader.astro';
import { ArrowRight } from '../components/icons/ArrowRight';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout pageTitle="Projects">
  <section class="w-full max-w-[1120px] mx-auto px-4 pt-40 pb-28">
    <!-- Back -->
    <a href="/" class="invisible animate-fade-up inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors mb-12 group">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300 group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to home
    </a>

    <!-- Header -->
    <div class="invisible animate-fade-up">
      <ProjectHeader forHomePage />
    </div>

    <!-- Project Grid -->
    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sortedProjects.map((project, i) => {
        const url = project.data.url || '#';
        const isExternal = url.startsWith('http');
        const isIcon = project.data.imageStyle === 'icon';
        const delayClass = i === 0 ? 'animate-fade-up-200' : i === 1 ? 'animate-fade-up-400' : 'animate-fade-up-600';

        return (
          <a
            href={url}
            target={isExternal ? '_blank' : '_self'}
            rel={isExternal ? 'noopener noreferrer' : undefined}
            class:list={['invisible group block', delayClass]}
          >
            <div class="h-full rounded-2xl border border-[#2A3441] bg-[#0f1219] overflow-hidden transition-all duration-300 group-hover:border-[#3A4A5A] group-hover:bg-[#131922]">
              {isIcon ? (
                <div class="flex items-center justify-center h-52 bg-gradient-to-b from-[#1a2130] to-[#0f1219]">
                  <img
                    src={project.data.heroImage}
                    alt={project.data.title}
                    class="w-20 h-20 rounded-2xl transition-transform duration-500 group-hover:scale-110"
                  />
                </div>
              ) : (
                <div class="overflow-hidden">
                  <img
                    src={project.data.heroImage}
                    alt={project.data.title}
                    class:list={[
                      'w-full h-52 object-cover transition-transform duration-500 group-hover:scale-105',
                      { 'object-top': project.data.heroImageAlign === 'top' },
                      { 'object-center': project.data.heroImageAlign === 'center' },
                      { 'object-bottom': project.data.heroImageAlign === 'bottom' }
                    ]}
                  />
                </div>
              )}

              <div class="p-6 space-y-3">
                <div class="flex items-center justify-between">
                  <h3 class="text-lg font-semibold text-white">{project.data.title}</h3>
                  <span class="text-xs text-zinc-500 tabular-nums">{project.data.year}</span>
                </div>
                <p class="text-sm text-zinc-400 leading-relaxed">{project.data.description}</p>
                <span class="inline-flex items-center text-sm text-emerald-400 group-hover:text-emerald-300 transition-colors">
                  View project
                  <ArrowRight className="ml-1 w-3.5 h-3.5 transition-all duration-300 group-hover:ml-2" />
                </span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</BaseLayout>
